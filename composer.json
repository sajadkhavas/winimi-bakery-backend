{
    "name": "winimi/bakery-backend",
    "type": "project",
    "description": "Winimi Bakery Laravel 12 headless commerce backend with Filament administration",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "awcodes/filament-curator": "^3.7",
        "awcodes/filament-tiptap-editor": "^3.0",
        "bezhansalleh/filament-exceptions": "^3.0",
        "bezhansalleh/filament-google-analytics": "^2.1",
        "bezhansalleh/filament-language-switch": "^3.1",
        "bezhansalleh/filament-shield": "^3.2",
        "coderflex/filament-turnstile": "^2.4",
        "dotswan/filament-laravel-pulse": "^1.1",
        "filament/filament": "^3.3.53",
        "filament/spatie-laravel-media-library-plugin": "^3.3.53",
        "guzzlehttp/guzzle": "^7.12.1",
        "laravel/fortify": "^1.37",
        "laravel/framework": "^12.61.1",
        "laravel/pulse": "^1.7",
        "laravel/sanctum": "^4.0",
        "laravel/telescope": "^5.20",
        "laravel/tinker": "^2.9",
        "malzariey/filament-daterangepicker-filter": "^3.4",
        "pxlrbt/filament-excel": "^2.5",
        "ralphjsmit/laravel-seo": "^1.8",
        "rmsramos/activitylog": "^2.0",
        "shuvroroy/filament-spatie-laravel-backup": "^2.2",
        "spatie/laravel-backup": "^9.3",
        "spatie/laravel-medialibrary": "^11.0",
        "spatie/laravel-sitemap": "^7.2",
        "spatie/laravel-sluggable": "^3.5",
        "tapp/filament-authentication-log": "^4.0",
        "torann/geoip": "^3.0",
        "z3d0x/filament-fabricator": "^2.7"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "test": [
            "@php artisan test"
        ],
        "format:check": [
            "@php vendor/bin/pint --test app/Support app/Http/Middleware/AttachApiContext.php app/Http/Middleware/MarkLegacyApi.php app/Http/Controllers/Api/SystemController.php app/Models/Product.php app/Http/Resources/ProductResource.php bootstrap/app.php config/cors.php config/winimi.php routes/api.php database/migrations/2024_01_01_000000_create_personal_access_tokens_table.php database/migrations/2026_06_11_152702_create_jobs_table.php database/migrations/2026_06_11_154204_create_failed_jobs_table.php tests scripts/audit-backend-foundation.php"
        ],
        "check": [
            "@php scripts/audit-backend-foundation.php",
            "@format:check",
            "@php artisan route:list --except-vendor",
            "@php artisan test"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
