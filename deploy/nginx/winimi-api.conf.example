# Replace certificate paths only after ACME issuance, then run nginx -t.

server {
    listen 80;
    listen [::]:80;
    server_name api.winimibakery.com;

    location /.well-known/acme-challenge/ {
        root /var/www/letsencrypt;
    }

    location / {
        return 301 https://api.winimibakery.com$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api.winimibakery.com;

    root /var/www/winimi/backend/current/public;
    index index.php;
    charset utf-8;
    server_tokens off;

    ssl_certificate /etc/letsencrypt/live/api.winimibakery.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.winimibakery.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;
    add_header X-Frame-Options "SAMEORIGIN" always;

    client_max_body_size 25m;

    location = /favicon.ico { access_log off; log_not_found off; }
    location = /robots.txt  { access_log off; log_not_found off; }

    location ^~ /storage/ {
        try_files $uri =404;
        add_header Cache-Control "public, max-age=86400, stale-while-revalidate=604800" always;
        access_log off;
    }

    location ~* \.(?:css|js|png|jpg|jpeg|gif|webp|svg|ico|woff2?)$ {
        try_files $uri =404;
        add_header Cache-Control "public, max-age=604800, stale-while-revalidate=2592000" always;
        access_log off;
    }

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_param DOCUMENT_ROOT $realpath_root;
        fastcgi_param HTTP_PROXY "";
        fastcgi_param HTTPS on;
        fastcgi_param HTTP_X_FORWARDED_PROTO https;
        fastcgi_pass unix:/run/php/php8.3-fpm.sock;
        fastcgi_read_timeout 60s;
        fastcgi_hide_header X-Powered-By;
    }

    location ~* /(?:\.env|composer\.(?:json|lock)|artisan|phpunit\.xml|server\.php)$ {
        return 404;
    }

    location ~ /\. {
        return 404;
    }
}
