APP_NAME="Winimi Bakery Backend"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Tehran
APP_URL=http://localhost:8000
APP_LOCALE=fa
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fa_IR

WINIMI_BRAND_NAME="وینیمی بیکری"
WINIMI_BRAND_NAME_EN="Winimi Bakery"
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173,http://localhost:4173
LEGACY_TOOLMASTER_API_ENABLED=true

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:4173,localhost:8000,127.0.0.1:5173,127.0.0.1:8000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=winimi

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@winimibakery.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ADMIN_ADDRESS="admin@winimibakery.com"

# OTP is disabled by default. Use "testing" only in local/testing environments.
SMS_PROVIDER=disabled
OTP_LENGTH=6
OTP_EXPIRES_SECONDS=120
OTP_RETRY_AFTER_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_EXPOSE_TEST_CODE=false
KAVENEGAR_API_KEY=
KAVENEGAR_TEMPLATE=
KAVENEGAR_BASE_URL=https://api.kavenegar.com/v1

# Checkout stays disabled until delivery fees and operating rules are approved.
CHECKOUT_ENABLED=false
INVENTORY_RESERVATION_MINUTES=20
CHECKOUT_MAX_QUANTITY_PER_LINE=20
CHECKOUT_MAX_TOTAL_UNITS=50
CHECKOUT_PACKAGING_FEE_TOMAN=0
DELIVERY_STANDARD_ENABLED=false
DELIVERY_STANDARD_FEE_TOMAN=0
DELIVERY_CHILLED_ENABLED=false
DELIVERY_CHILLED_FEE_TOMAN=0
DELIVERY_PICKUP_ENABLED=false
DELIVERY_PICKUP_FEE_TOMAN=0

PAYMENT_PROVIDER=disabled
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true
ZARINPAL_CALLBACK_URL=http://localhost:5173/payment/result

BACKUP_DISK=local
TELESCOPE_ENABLED=false
PULSE_ENABLED=false

VITE_APP_NAME="${APP_NAME}"
