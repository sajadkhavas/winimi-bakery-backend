APP_NAME="Winimi Bakery Backend"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Tehran
APP_URL=http://localhost:8000
APP_LOCALE=fa
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fa_IR

WINIMI_BRAND_NAME="وینیمی بیکری"
WINIMI_BRAND_NAME_EN="Winimi Bakery"
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173,http://localhost:4173
LEGACY_TOOLMASTER_API_ENABLED=true

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:4173,localhost:8000,127.0.0.1:5173,127.0.0.1:8000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=winimi

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@winimibakery.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ADMIN_ADDRESS="admin@winimibakery.com"

# Server-only integrations. Never expose these values through VITE_* variables.
SMS_PROVIDER=disabled
KAVENEGAR_API_KEY=
KAVENEGAR_TEMPLATE=

PAYMENT_PROVIDER=disabled
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true
ZARINPAL_CALLBACK_URL=http://localhost:5173/payment/result

BACKUP_DISK=local
TELESCOPE_ENABLED=false
PULSE_ENABLED=false

VITE_APP_NAME="${APP_NAME}"
